{
	"_version": "1.84.0",
	"sap.app": {
		"id": "assetintelui",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [""]
		},
		"applicationVersion": { "version": "0.0.1" },
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.24.0",
			"toolsId": "47c8fca3-c39a-4769-828d-3b1d8d48e2ff"
		},
		"dataSources": {
			"annotation": {
				"type": "ODataAnnotation",
				"uri": "annotations/annotation.xml",
				"settings": { "localUri": "annotations/annotation.xml" }
			},
			"mainService": {
				"uri": "https://asset-intel-srv-smart-eland-qh.cfapps.us10-001.hana.ondemand.com/asset/",
				"type": "OData",
				"settings": {
					"annotations": ["annotation"],
					"localUri": "localService/mainService/metadata.xml",
					"odataVersion": "4.01"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": { "icon": "", "favIcon": "", "phone": "", "phone@2": "", "tablet": "", "tablet@2": "" },
		"deviceTypes": { "desktop": true, "tablet": true, "phone": true }
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.148.0",
			"libs": { "sap.m": {}, "sap.ui.core": {}, "sap.fe.templates": {} }
		},
		"contentDensities": { "compact": true, "cozy": true },
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": { "bundleName": "assetintelui.i18n.i18n", "supportedLocales": [""] }
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": { "operationMode": "Server", "autoExpandSelect": true, "earlyRequests": false }
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": { "supportedLocales": [""] }
			}
		},
		"resources": { "css": [] },
		"routing": {
			"config": {},
			"routes": [
				{ "pattern": ":?query:", "name": "AssetsList", "target": "AssetsList" },
				{ "pattern": "Assets({key}):?query:", "name": "AssetsObjectPage", "target": "AssetsObjectPage" }
			],
			"targets": {
				"AssetsList": {
					"type": "Component",
					"id": "AssetsList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/Assets",
							"variantManagement": "None",
							"initialLoad": "Disabled",
							"navigation": { "Assets": { "detail": { "route": "AssetsObjectPage" } } },
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": { "type": "ResponsiveTable" }
								}
							}
						}
					}
				},
				"AssetsObjectPage": {
					"type": "Component",
					"id": "AssetsObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/Assets",
							"content": {
								"header": {
									"actions": {
										"generateAnalysis": {
											"press": "onLoadAnalysis",
											"text": "AI Insights",
											"enabled": true,
											"visible": true
										}
									}
								}
							}
						}
					}
				}
			}
		},
"flexBundle": false
	},
	"sap.fiori": { "registrationIds": [], "archeType": "transactional" },
	"sap.fe": { "app": { "enableLazyLoading": true } }
}
